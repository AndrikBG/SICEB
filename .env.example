# ==============================
# SICEB — Local Environment
# ==============================
# Copy this file to .env and adjust values as needed.
# NEVER commit the .env file to version control.

# --- Database ---
DB_NAME=siceb
DB_USER=siceb
DB_PASSWORD=siceb_dev_password
DB_PORT=5432
DB_POOL_SIZE=10
# SSL: empty for local Docker; for cloud use: ?sslmode=require&sslrootcert=/path/to/cert
DB_SSL_PARAMS=

# --- JWT ---
JWT_SECRET=dev-secret-key-must-be-at-least-256-bits-long-for-hs256
JWT_EXPIRATION=3600

# --- API Server ---
API_PORT=8080

# --- PWA Client ---
PWA_PORT=5173

# --- CORS ---
CORS_ORIGINS=http://localhost:5173
